# -- Dependencies --------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -- Next.js build output ------------------------------------------
/.next/
/out/
/build

# -- Testing -------------------------------------------------------
/coverage

# -- Environment files (NEVER commit real secrets) ----------------
# .env.local is local-only and safe to ignore.
# .env.production may contain real API URLs/keys  also ignore.
.env
.env.*
.env*.local
.env.production
.env.staging

# -- TypeScript generated files ------------------------------------
*.tsbuildinfo
next-env.d.ts

# -- Vercel deploy -------------------------------------------------
.vercel

# -- OS metadata ---------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -- Editor --------------------------------------------------------
.idea/
.vscode/settings.json
*.swp
*~

# -- Debug logs ----------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -- TLS certs (sometimes generated locally) ----------------------
*.pem